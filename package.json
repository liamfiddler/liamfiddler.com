{
  "name": "liamfiddler.com",
  "version": "4.0.0",
  "description": "Liam Fiddler's personal website",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "eleventy --config=.eleventy.cjs --input=src --serve",
    "build": "eleventy --config=.eleventy.cjs --input=src",
    "serve": "npx http-server _site",
    "clean": "rm -rf ./_site",
    "build:clean": "npm run clean && npm run build",
    "serve:clean": "npm run build:clean && npm run serve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "@liamfiddler",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@lit-labs/eleventy-plugin-lit": "^1.0.3",
    "esbuild": "^0.21.0",
    "html2plaintext": "^2.1.4",
    "lit": "^3.1.3",
    "luxon": "^3.4.4",
    "markdown-it-admon": "^1.0.1",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.12.0",
    "stopword": "^3.0.1"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.0.5",
    "@lit/task": "^1.0.3",
    "clipboard-polyfill": "^4.1.0",
    "fuse.js": "^7.0.0"
  }
}
